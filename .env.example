# === LINE Messaging API ===
# 取得方式：LINE Developers Console → Messaging API → Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here
# 取得方式：Basic settings → Channel secret
LINE_CHANNEL_SECRET=your_channel_secret_here

# === Anthropic Claude API ===
# 取得方式：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 模型：claude-haiku-4-5 / claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5

# === Server ===
# ngrok 給的 HTTPS URL，圖片 URL 會基於這個組（結尾不要斜線）
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# === 可選 ===
DB_PATH=./data/expenses.db
AGENT_MAX_ITERATIONS=5
HISTORY_WINDOW=6
